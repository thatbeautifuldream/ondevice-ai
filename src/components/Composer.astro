---
import Icon from "./Icon.astro";
---

<div class="relative shrink-0 px-3 pb-3 pt-4 sm:px-4 sm:pb-4 sm:pt-6">
	<div class="pointer-events-none absolute inset-x-0 -top-16 h-16 bg-linear-to-b from-transparent to-white dark:to-zinc-950"></div>
	<form id="composer-form" class="relative mx-auto w-full max-w-3xl">
		<div
			class="flex items-end gap-2 rounded-3xl bg-zinc-50 p-2 shadow-sm ring-1 ring-zinc-950/5 transition-shadow focus-within:ring-2 focus-within:ring-accent/40 dark:bg-white/5 dark:ring-white/10"
		>
			<label for="composer-input" class="sr-only">Message</label>
			<textarea
				id="composer-input"
				name="message"
				rows="1"
				placeholder="Message the on-device model…"
				class="scrollbar-thin max-h-48 min-h-[1.75rem] flex-1 resize-none bg-transparent px-2.5 py-1.5 text-base text-zinc-900 placeholder:text-zinc-400 focus:outline-none sm:text-sm dark:text-zinc-100 dark:placeholder:text-zinc-500"
			></textarea>

			<button
				type="submit"
				id="send-btn"
				class="relative flex size-9 shrink-0 items-center justify-center rounded-full bg-accent text-accent-fg shadow-sm transition-colors hover:bg-accent-hover focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent disabled:cursor-not-allowed disabled:bg-zinc-200 disabled:text-zinc-400 dark:shadow-none dark:disabled:bg-white/10 dark:disabled:text-zinc-500"
				aria-label="Send message"
				disabled
			>
				<span class="absolute top-1/2 left-1/2 size-[max(100%,3rem)] -translate-x-1/2 -translate-y-1/2" aria-hidden="true"></span>
				<span id="send-icon" class="flex"><Icon name="arrow-up" class="size-4" /></span>
				<span id="stop-icon" class="hidden"><Icon name="stop" class="size-4" /></span>
			</button>
		</div>
	</form>
</div>
