---
import Icon from "./Icon.astro";
---

<header class="flex h-14 shrink-0 items-center gap-2 px-3 sm:px-4">
	<button
		type="button"
		id="menu-btn"
		class="relative flex size-9 items-center justify-center rounded-md text-zinc-600 hover:bg-zinc-950/5 hover:text-zinc-900 dark:text-zinc-300 dark:hover:bg-white/10 dark:hover:text-white"
		aria-label="Toggle conversations"
	>
		<span class="absolute top-1/2 left-1/2 size-[max(100%,3rem)] -translate-x-1/2 -translate-y-1/2" aria-hidden="true"></span>
		<Icon name="bars-3" />
	</button>

	<h2 id="chat-title" class="min-w-0 flex-1 truncate text-sm font-semibold tracking-tight">New chat</h2>

	<div
		id="context-pill"
		class="hidden items-center gap-2 rounded-full bg-zinc-100 px-2.5 py-1 text-xs text-zinc-500 sm:flex dark:bg-white/5 dark:text-zinc-400"
		title="Context window usage"
	>
		<span class="relative block h-1.5 w-16 overflow-hidden rounded-full bg-zinc-950/10 dark:bg-white/10">
			<span id="context-bar" class="block h-full w-0 rounded-full bg-accent transition-all duration-300"></span>
		</span>
		<span class="tabular-nums" id="context-text">—</span>
	</div>
</header>
