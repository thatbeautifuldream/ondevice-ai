---
import Icon from "./Icon.astro";
---

<dialog
	id="settings-dialog"
	class="m-auto w-[min(100vw,32rem)] rounded-2xl border-0 bg-white p-0 text-zinc-900 shadow-2xl backdrop:bg-zinc-950/50 dark:bg-zinc-900 dark:text-zinc-100"
>
	<div class="flex items-center justify-between border-b border-zinc-950/5 px-5 py-4 dark:border-white/10">
		<h2 class="text-base font-semibold tracking-tight">Settings</h2>
		<button
			type="button"
			id="settings-close"
			class="relative flex size-8 items-center justify-center rounded-md text-zinc-500 hover:bg-zinc-950/5 hover:text-zinc-700 dark:text-zinc-400 dark:hover:bg-white/10 dark:hover:text-zinc-200"
			aria-label="Close settings"
		>
			<span class="absolute top-1/2 left-1/2 size-[max(100%,3rem)] -translate-x-1/2 -translate-y-1/2" aria-hidden="true"></span>
			<Icon name="x-mark" />
		</button>
	</div>

	<div class="flex max-h-[70vh] flex-col gap-6 overflow-y-auto px-5 py-5 scrollbar-thin">
		<div class="flex flex-col gap-2">
			<label for="setting-system" class="text-sm font-medium text-zinc-900 dark:text-white">System prompt</label>
			<p class="text-sm text-zinc-500 dark:text-zinc-400">Sets the model's behavior for every new conversation.</p>
			<textarea
				id="setting-system"
				name="system"
				rows="3"
				class="scrollbar-thin w-full resize-none rounded-lg bg-zinc-50 px-3 py-2 text-sm text-zinc-900 ring-1 ring-zinc-950/10 transition-shadow placeholder:text-zinc-400 focus:outline-none focus:ring-2 focus:ring-emerald-500/40 max-sm:text-base dark:bg-white/5 dark:text-zinc-100 dark:ring-white/10 dark:placeholder:text-zinc-500"
				placeholder="You are a helpful, friendly assistant."
			></textarea>
		</div>

		<div id="param-controls" class="hidden flex-col gap-5">
			<div class="flex flex-col gap-2">
				<div class="flex items-baseline justify-between">
					<label for="setting-temperature" class="text-sm font-medium text-zinc-900 dark:text-white">Temperature</label>
					<span class="text-sm tabular-nums text-zinc-500 dark:text-zinc-400" id="temperature-value">1.0</span>
				</div>
				<input
					type="range"
					id="setting-temperature"
					name="temperature"
					min="0"
					max="2"
					step="0.1"
					class="w-full accent-emerald-600 dark:accent-emerald-400"
				/>
				<p class="text-sm text-zinc-500 dark:text-zinc-400">Higher values produce more creative, varied responses.</p>
			</div>

			<div class="flex flex-col gap-2">
				<div class="flex items-baseline justify-between">
					<label for="setting-topk" class="text-sm font-medium text-zinc-900 dark:text-white">Top-K</label>
					<span class="text-sm tabular-nums text-zinc-500 dark:text-zinc-400" id="topk-value">3</span>
				</div>
				<input
					type="range"
					id="setting-topk"
					name="topk"
					min="1"
					max="128"
					step="1"
					class="w-full accent-emerald-600 dark:accent-emerald-400"
				/>
				<p class="text-sm text-zinc-500 dark:text-zinc-400">Limits the model to the top-K likely next tokens.</p>
			</div>
			<p class="rounded-lg bg-zinc-50 px-3 py-2 text-xs text-zinc-500 dark:bg-white/5 dark:text-zinc-400">
				Parameter tuning is available via the Prompt API Origin Trial or Chrome Extensions. These apply to new conversations only.
			</p>
		</div>

		<div class="border-t border-zinc-950/5 pt-5 dark:border-white/10">
			<button
				type="button"
				id="clear-all-btn"
				class="relative flex items-center gap-2 rounded-lg px-3 py-2 text-sm font-medium text-red-600 transition-colors hover:bg-red-50 dark:text-red-400 dark:hover:bg-red-500/10"
			>
				<span class="absolute top-1/2 left-1/2 size-[max(100%,3rem)] -translate-x-1/2 -translate-y-1/2" aria-hidden="true"></span>
				<Icon name="trash" />
				Delete all conversations
			</button>
		</div>
	</div>
</dialog>
