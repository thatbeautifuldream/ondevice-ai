---
import Layout from "../layouts/Layout.astro";
import Sidebar from "../components/Sidebar.astro";
import ChatHeader from "../components/ChatHeader.astro";
import EmptyState from "../components/EmptyState.astro";
import Composer from "../components/Composer.astro";
import SettingsDialog from "../components/SettingsDialog.astro";
import UnavailableNotice from "../components/UnavailableNotice.astro";
import Icon from "../components/Icon.astro";
---

<Layout>
	<div id="app" class="flex h-dvh overflow-hidden isolate">
		<Sidebar />

		<main class="flex min-w-0 flex-1 flex-col bg-white dark:bg-zinc-950">
			<ChatHeader />

			<div id="messages-scroll" class="scrollbar-thin flex flex-1 flex-col overflow-y-auto">
				<UnavailableNotice />

				<div id="empty-state" class="grid min-h-full place-items-center">
					<EmptyState />
				</div>

				<ol
					id="message-list"
					class="mx-auto hidden w-full max-w-3xl flex-col gap-6 px-4 py-8"
					role="list"
				>
				</ol>

			<!-- Download / availability banner, shown when the model needs downloading -->
			<div
				id="download-banner"
				class="mx-auto hidden w-full max-w-3xl px-4"
			>
				<div class="flex items-center gap-3 rounded-xl border border-zinc-950/10 bg-zinc-50 p-4 dark:border-white/10 dark:bg-white/5">
					<span class="text-accent"><Icon name="sparkles" class="size-4" /></span>
					<div class="min-w-0 flex-1">
						<p class="text-sm font-medium text-zinc-900 dark:text-white">Downloading the on-device model</p>
						<p id="download-status" class="mt-0.5 text-sm text-zinc-500 dark:text-zinc-400">Preparing…</p>
						<div class="mt-2 h-1.5 w-full overflow-hidden rounded-full bg-zinc-950/10 dark:bg-white/10">
							<div id="download-bar" class="h-full w-0 rounded-full bg-accent transition-all" style="--w: 0%"></div>
						</div>
					</div>
				</div>
			</div>

			<!-- Compaction status banner, shown while summarizing older messages -->
			<div
				id="compact-banner"
				class="mx-auto hidden w-full max-w-3xl px-4"
			>
				<div class="flex items-center gap-2 rounded-xl border border-zinc-950/10 bg-zinc-50 px-3 py-2 text-sm text-zinc-600 dark:border-white/10 dark:bg-white/5 dark:text-zinc-300">
					<span class="text-accent"><Icon name="arrow-path" class="size-4" /></span>
					<span id="compact-status" class="min-w-0 flex-1">Summarizing older messages…</span>
				</div>
			</div>
			</div>

			<Composer />
		</main>

		<SettingsDialog />
	</div>
</Layout>

<script>
	import { startApp } from "../scripts/chat";
	startApp();
</script>
