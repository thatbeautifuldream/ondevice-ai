---
import Layout from "../layouts/Layout.astro";
import Icon from "../components/Icon.astro";

const presetButtons = [
	{ id: "pottery", label: "Boolean" },
	{ id: "hashtags", label: "Array + pattern" },
	{ id: "sentiment", label: "Enum" },
	{ id: "review", label: "Object" },
	{ id: "palette", label: "Nested" },
];

const snippet = [
	'<span class="text-zinc-500">// Chrome 137+ · runs entirely on-device</span>',
	'<span class="text-sky-300">const</span> session = <span class="text-sky-300">await</span> LanguageModel.<span class="text-emerald-300">create</span>();',
	'<span class="text-sky-300">const</span> result = <span class="text-sky-300">await</span> session.<span class="text-emerald-300">prompt</span>(prompt, {',
	'  responseConstraint: { <span class="text-sky-300">type</span>: <span class="text-emerald-300">"boolean"</span> },',
	'});',
	'<span class="text-sky-300">const</span> data = <span class="text-emerald-300">JSON</span>.<span class="text-emerald-300">parse</span>(result); <span class="text-zinc-500">// &rarr; true</span>',
].join("\n");
---

<Layout
	title="Structured Output Playground — Chat"
	description="Experiment with the Prompt API responseConstraint option to force Chrome's on-device model to reply with JSON that matches a JSON Schema."
>
	<div class="min-h-dvh">
		<header
			class="sticky top-0 z-30 border-b border-zinc-950/5 bg-white/80 backdrop-blur dark:border-white/10 dark:bg-zinc-950/80"
		>
			<div class="mx-auto flex h-14 max-w-6xl items-center gap-3 px-4 sm:px-6">
				<a
					href="/"
					class="relative flex items-center gap-1.5 rounded-md px-2 py-1.5 text-sm font-medium text-zinc-600 transition-colors hover:bg-zinc-950/5 hover:text-zinc-900 dark:text-zinc-300 dark:hover:bg-white/10 dark:hover:text-white"
				>
					<span class="absolute top-1/2 left-1/2 size-[max(100%,3rem)] -translate-x-1/2 -translate-y-1/2" aria-hidden="true"></span>
					<Icon name="arrow-left" class="size-4" />
					Chat
				</a>
				<span class="text-emerald-600 dark:text-emerald-400"><Icon name="sparkles" class="size-4" /></span>
				<span class="text-sm font-semibold tracking-tight">Chat</span>
				<div
					id="pg-model-status"
					class="ml-auto flex items-center gap-2 rounded-full bg-zinc-100 px-2.5 py-1 text-xs text-zinc-500 dark:bg-white/5 dark:text-zinc-400"
				>
					<span id="pg-model-dot" class="size-2 shrink-0 rounded-full bg-zinc-300 dark:bg-zinc-600"></span>
					<span id="pg-model-label" class="truncate">Checking model…</span>
				</div>
			</div>
		</header>

		<main class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-14">
			<p class="font-mono text-xs font-medium tracking-wide text-emerald-600 uppercase dark:text-emerald-400">
				Chrome Prompt API · Structured Output
			</p>
			<h1 class="mt-2 text-3xl font-semibold tracking-tight text-balance sm:text-4xl">
				Force the model to reply with valid JSON
			</h1>
			<p class="mt-3 max-w-2xl text-base text-pretty text-zinc-600 sm:text-lg dark:text-zinc-400">
				Pass a <a class="font-medium text-emerald-700 underline underline-offset-2 hover:text-emerald-800 dark:text-emerald-400 dark:hover:text-emerald-300" href="https://json-schema.org/" rel="noopener" target="_blank">JSON Schema</a> to the Prompt API's
				<code class="rounded bg-zinc-100 px-1.5 py-0.5 font-mono text-[0.8125em] text-zinc-700 dark:bg-white/10 dark:text-zinc-300">responseConstraint</code> option and the on-device model returns a string you can <em>parse</em> with confidence — no regex rescue required.
			</p>

			<section class="mt-8" aria-label="Preset examples">
				<h2 class="sr-only">Presets</h2>
				<div id="pg-presets" class="flex flex-wrap gap-2">
					{presetButtons.map((p, i) => (
						<button
							type="button"
							data-id={p.id}
							aria-pressed={i === 0 ? "true" : "false"}
							class="relative rounded-full px-3 py-1.5 text-xs font-medium ring-1 transition-colors sm:text-sm"
						>
							<span class="absolute top-1/2 left-1/2 size-[max(100%,3rem)] -translate-x-1/2 -translate-y-1/2" aria-hidden="true"></span>
							{p.label}
						</button>
					))}
				</div>
			</section>

			<div id="pg-unavailable" class="mt-8 hidden">
				<div class="flex items-start gap-3 rounded-xl border border-amber-500/20 bg-amber-50 p-4 text-sm text-amber-800 dark:bg-amber-500/10 dark:text-amber-300">
					<span class="mt-0.5 shrink-0 text-amber-500"><Icon name="exclamation-triangle" class="size-5" /></span>
					<div>
						<p class="font-semibold">On-device AI isn't available here.</p>
						<p class="mt-1 text-pretty">Structured output needs Chrome 137+ with the built-in Prompt API enabled. Open this page in a recent Chrome desktop build on a supported device.</p>
					</div>
				</div>
			</div>

			<div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-2">
				<section
					class="flex flex-col rounded-2xl border border-zinc-950/10 bg-white p-5 dark:border-white/10 dark:bg-white/5"
					aria-label="Input"
				>
					<div class="flex items-center gap-2">
						<Icon name="code-bracket" class="size-4 text-zinc-400 dark:text-zinc-500" />
						<h2 class="text-sm font-semibold tracking-tight text-zinc-900 dark:text-white">Input</h2>
					</div>

					<div class="mt-4">
						<label for="pg-instruction" class="text-xs font-medium text-zinc-500 dark:text-zinc-400">Instruction</label>
						<input
							id="pg-instruction"
							name="instruction"
							type="text"
							class="mt-1 w-full rounded-xl bg-zinc-50 px-3 py-2 text-sm text-zinc-900 ring-1 ring-zinc-950/10 focus:ring-2 focus:ring-emerald-500/40 focus:outline-none sm:text-base dark:bg-white/5 dark:text-zinc-100 dark:ring-white/10"
						/>
					</div>

					<div class="mt-4">
						<label for="pg-input" class="text-xs font-medium text-zinc-500 dark:text-zinc-400">Content to analyze</label>
						<textarea
							id="pg-input"
							name="input"
							rows="4"
							class="scrollbar-thin mt-1 w-full resize-y rounded-xl bg-zinc-50 px-3 py-2 text-sm text-zinc-900 ring-1 ring-zinc-950/10 focus:ring-2 focus:ring-emerald-500/40 focus:outline-none sm:text-base dark:bg-white/5 dark:text-zinc-100 dark:ring-white/10"
						></textarea>
					</div>

					<div class="mt-4 flex items-center gap-2">
						<label for="pg-schema" class="text-xs font-medium text-zinc-500 dark:text-zinc-400">
							Response schema
							<span class="font-mono text-zinc-400 dark:text-zinc-500">(responseConstraint)</span>
						</label>
						<button
							id="pg-format"
							type="button"
							class="relative ml-auto inline-flex items-center gap-1 rounded-md px-2 py-1 text-xs text-zinc-500 transition-colors hover:bg-zinc-950/5 hover:text-zinc-700 dark:text-zinc-400 dark:hover:bg-white/10 dark:hover:text-zinc-200"
						>
							<span class="absolute top-1/2 left-1/2 size-[max(100%,3rem)] -translate-x-1/2 -translate-y-1/2" aria-hidden="true"></span>
							Format
						</button>
					</div>
					<textarea
						id="pg-schema"
						name="schema"
						rows="12"
						spellcheck="false"
						autocapitalize="off"
						autocomplete="off"
						class="scrollbar-thin mt-1 w-full resize-y rounded-xl bg-zinc-900 p-3.5 font-mono text-[0.8125rem]/6 text-zinc-100 ring-1 ring-white/10 focus:ring-2 focus:ring-emerald-500/40 focus:outline-none"
					></textarea>
					<p id="pg-schema-error" class="mt-1.5 text-xs text-red-600 dark:text-red-400"></p>
					<p class="mt-1 text-xs text-zinc-400 dark:text-zinc-500">
						Edit the schema freely — the response is validated against it on the client.
					</p>
				</section>

				<section
					class="flex flex-col rounded-2xl border border-zinc-950/10 bg-white p-5 dark:border-white/10 dark:bg-white/5"
					aria-label="Output"
				>
					<div class="flex items-center gap-2">
						<Icon name="sparkles" class="size-4 text-zinc-400 dark:text-zinc-500" />
						<h2 class="text-sm font-semibold tracking-tight text-zinc-900 dark:text-white">Output</h2>
					</div>

					<div class="mt-4 flex flex-wrap items-center gap-2">
						<button
							id="pg-run"
							type="button"
							class="relative inline-flex items-center gap-1.5 rounded-xl bg-emerald-600 py-2 pr-3 pl-2 text-sm font-medium text-white shadow-sm transition-colors hover:bg-emerald-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-600 disabled:cursor-not-allowed disabled:bg-zinc-200 disabled:text-zinc-400 dark:shadow-none dark:disabled:bg-white/10 dark:disabled:text-zinc-500"
						>
							<span class="absolute top-1/2 left-1/2 size-[max(100%,3rem)] -translate-x-1/2 -translate-y-1/2" aria-hidden="true"></span>
							<span id="pg-run-icon" class="flex"><Icon name="play" class="size-4" /></span>
							<span id="pg-run-label">Run</span>
						</button>
						<button
							id="pg-compare"
							type="button"
							class="relative inline-flex items-center rounded-xl bg-white px-3 py-2 text-sm font-medium text-zinc-700 ring-1 ring-zinc-950/10 transition-colors hover:bg-zinc-50 hover:text-zinc-900 disabled:cursor-not-allowed disabled:opacity-50 dark:bg-white/5 dark:text-zinc-300 dark:ring-white/10 dark:hover:bg-white/10 dark:hover:text-white"
						>
							<span class="absolute top-1/2 left-1/2 size-[max(100%,3rem)] -translate-x-1/2 -translate-y-1/2" aria-hidden="true"></span>
							Compare without constraint
						</button>
					</div>

					<div id="pg-download" class="mt-4 hidden">
						<div class="flex items-center gap-3 rounded-xl border border-zinc-950/10 bg-zinc-50 p-3 dark:border-white/10 dark:bg-white/5">
							<span class="text-emerald-600 dark:text-emerald-400"><Icon name="sparkles" class="size-4" /></span>
							<div class="min-w-0 flex-1">
								<p class="text-sm font-medium text-zinc-900 dark:text-white">Downloading the on-device model</p>
								<p id="pg-download-status" class="mt-0.5 text-xs text-zinc-500 dark:text-zinc-400">Preparing…</p>
								<div class="mt-2 h-1.5 w-full overflow-hidden rounded-full bg-zinc-950/10 dark:bg-white/10">
									<div id="pg-download-bar" class="h-full w-0 rounded-full bg-emerald-500 transition-all"></div>
								</div>
							</div>
						</div>
					</div>

					<div
						id="pg-s-card"
						class="mt-4 rounded-xl border border-zinc-950/10 bg-zinc-50/60 p-4 dark:border-white/10 dark:bg-white/[0.03]"
					>
						<div class="flex flex-wrap items-center justify-between gap-2">
							<div class="flex items-center gap-2">
								<span id="pg-s-badge"></span>
								<span id="pg-s-latency" class="text-xs text-zinc-400 tabular-nums dark:text-zinc-500"></span>
							</div>
							<span class="text-xs font-medium text-zinc-500 dark:text-zinc-400">With responseConstraint</span>
						</div>
						<div id="pg-s-tabs" class="mt-3 hidden gap-4 border-b border-zinc-950/10 text-sm dark:border-white/10">
							<button type="button" data-tab="parsed" class="-mb-px border-b-2 px-1 pb-2">Parsed</button>
							<button type="button" data-tab="raw" class="-mb-px border-b-2 border-transparent px-1 pb-2 text-zinc-500 hover:text-zinc-800 dark:text-zinc-400 dark:hover:text-zinc-200">Raw</button>
						</div>
						<div id="pg-s-body" class="mt-3"></div>
						<div id="pg-s-parsed" class="mt-3"></div>
						<div id="pg-s-raw" class="mt-3 hidden"></div>
					</div>

					<div
						id="pg-f-card"
						class="mt-4 rounded-xl border border-zinc-950/10 bg-zinc-50/60 p-4 dark:border-white/10 dark:bg-white/[0.03]"
					>
						<div class="flex flex-wrap items-center justify-between gap-2">
							<div class="flex items-center gap-2">
								<span id="pg-f-badge"></span>
								<span id="pg-f-latency" class="text-xs text-zinc-400 tabular-nums dark:text-zinc-500"></span>
							</div>
							<span class="text-xs font-medium text-zinc-500 dark:text-zinc-400">No constraint</span>
						</div>
						<div id="pg-f-body" class="mt-3"></div>
					</div>
				</section>
			</div>

			<section class="mt-12 grid grid-cols-1 gap-6 lg:grid-cols-3" aria-label="How it works">
				<div class="lg:col-span-1">
					<h2 class="text-sm font-semibold tracking-tight text-zinc-900 dark:text-white">How it works</h2>
					<p class="mt-2 text-sm text-pretty text-zinc-600 dark:text-zinc-400">
						The Prompt API accepts a JSON Schema via
						<code class="rounded bg-zinc-100 px-1 py-0.5 font-mono text-[0.8125em] text-zinc-700 dark:bg-white/10 dark:text-zinc-300">responseConstraint</code>.
						The model then emits a string that conforms to it, so you can <code class="rounded bg-zinc-100 px-1 py-0.5 font-mono text-[0.8125em] text-zinc-700 dark:bg-white/10 dark:text-zinc-300">JSON.parse</code> the reply directly.
					</p>
				</div>
				<div class="lg:col-span-2">
					<pre class="scrollbar-thin overflow-x-auto rounded-xl bg-zinc-900 p-4 font-mono text-[0.8125rem]/6 text-zinc-100 ring-1 ring-white/10" set:html={snippet}></pre>
				</div>
			</section>

			<p class="mt-10 text-center text-xs text-zinc-400 dark:text-zinc-500">
				Based on <a class="font-medium text-zinc-500 underline underline-offset-2 hover:text-zinc-700 dark:text-zinc-400 dark:hover:text-zinc-200" href="https://web.dev/articles/structured-output-for-prompt-api" rel="noopener" target="_blank">Structured output for the Prompt API</a> by Thomas Steiner.
			</p>
		</main>
	</div>
</Layout>

<script>
	import { startPlayground } from "../scripts/structured-output";
	startPlayground();
</script>
